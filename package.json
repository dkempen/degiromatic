{
  "name": "degiromatic",
  "private": true,
  "scripts": {
    "start": "pnpm run build && node ./dist/src/main.js",
    "build": "tsc",
    "build:dev": "tsc --sourceMap",
    "dev": "tsc-watch --sourceMap --onSuccess \"node dist/src/main.js\"",
    "docker": "docker compose -f compose.dev.yaml up --build",
    "prettier": "prettier --write",
    "lint": "eslint --fix --max-warnings 0 --cache --cache-strategy content",
    "bundle": "rollup -c bundle/rollup.config.ts",
    "update": "pnpm self-update && pnpm update && pnpm audit && pnpm update --latest --interactive",
    "audit": "pnpm audit --json | node -p \"Object.values(JSON.parse(require('fs').readFileSync(0,'utf8')).metadata.vulnerabilities).reduce((a,b)=>a+b,0)\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@logtape/file": "^2.2.1",
    "@logtape/logtape": "^2.2.1",
    "croner": "^10.0.1",
    "degiro-api": "^1.0.6",
    "dotenv": "^17.4.2",
    "speakeasy": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/speakeasy": "^2.0.10",
    "eslint": "^10.6.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "tsc-watch": "^7.2.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": "^24",
    "pnpm": "^11"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11",
      "onFail": "download"
    }
  }
}
